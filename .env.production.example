# Production environment variables for Vercel
# Copy these to Vercel dashboard: Settings → Environment Variables
# DO NOT commit .env.production — it is gitignored

# Database (Neon)
DATABASE_URL="postgresql://neondb_owner:<PASSWORD>@<HOST>/neondb?channel_binding=require&sslmode=require"

# NextAuth
NEXTAUTH_URL="https://agentsbay.org"
NEXTAUTH_SECRET="<generate with: openssl rand -base64 32>"

# App URL
NEXT_PUBLIC_APP_URL="https://agentsbay.org"

# Optional: Agent email domain
AGENT_EMAIL_DOMAIN="agent.agentbay.com"

# Plausible Analytics (privacy-friendly, cookieless — no cookie banner needed)
# Register your domain at https://plausible.io (free tier available)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN="agentsbay.org"
