generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Agent {
  id                 String            @id
  userId             String
  name               String            @default("Agent")
  description        String?
  isActive           Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime
  deletedAt          DateTime?
  autoNegotiate      Boolean           @default(false)
  maxBidAmount       Int?
  minAcceptAmount    Int?
  maxAcceptAmount    Int?
  autoRejectBelow    Int?
  autoCounterEnabled Boolean           @default(false)
  requireApproval    Boolean           @default(true)
  preferredLocation  String?
  maxDistance        Int?
  currency           String?
  latitude           Float?
  locale             String?
  longitude          Float?
  User               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  AgentCredential    AgentCredential[]
  AgentSkill         AgentSkill[]
  AuditLog           AuditLog[]
  Bid                Bid[]
  Listing            Listing[]
  SkillExecution     SkillExecution[]
  WantedRequest      WantedRequest[]

  @@index([deletedAt])
  @@index([isActive])
  @@index([userId])
}

model AgentCredential {
  id        String   @id
  agentId   String
  provider  String
  apiKey    String
  createdAt DateTime @default(now())
  updatedAt DateTime
  Agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
}

model AgentSkill {
  id        String   @id
  agentId   String
  skillId   String
  isEnabled Boolean  @default(true)
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime
  Agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  Skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([agentId, skillId])
  @@index([agentId])
  @@index([skillId])
}

model AuditLog {
  id         String   @id
  userId     String?
  agentId    String?
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())
  Agent      Agent?   @relation(fields: [agentId], references: [id])
  User       User?    @relation(fields: [userId], references: [id])

  @@index([agentId])
  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([userId])
}

model Bid {
  id                String            @id
  threadId          String
  agentId           String?
  amount            Int
  message           String?
  status            BidStatus         @default(PENDING)
  expiresAt         DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime
  Agent             Agent?            @relation(fields: [agentId], references: [id])
  NegotiationThread NegotiationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([status])
  @@index([threadId])
}

model DeliveryRequest {
  id             String         @id
  orderId        String         @unique
  provider       String?
  trackingNumber String?
  status         DeliveryStatus @default(PENDING)
  fromAddress    String
  toAddress      String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime
  pickedUpAt     DateTime?
  deliveredAt    DateTime?
  Order          Order          @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
}

model Listing {
  id                String              @id
  userId            String
  agentId           String?
  title             String
  description       String
  category          ListingCategory
  condition         ItemCondition
  price             Int
  address           String
  status            ListingStatus       @default(DRAFT)
  confidence        Float?
  pickupAvailable   Boolean             @default(true)
  deliveryAvailable Boolean             @default(false)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  publishedAt       DateTime?
  soldAt            DateTime?
  deletedAt         DateTime?
  latitude          Float?
  longitude         Float?
  currency          String              @default("USD")
  labels            String[]            @default([])
  priceMax          Int?
  contactDiscord    String?
  contactTelegram   String?
  contactWhatsApp   String?
  Agent             Agent?              @relation(fields: [agentId], references: [id])
  User              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  ListingImage      ListingImage[]
  ModerationCase    ModerationCase[]
  NegotiationThread NegotiationThread[]
  Order             Order?

  @@index([agentId])
  @@index([category])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([price])
  @@index([status])
  @@index([userId])
}

model ListingImage {
  id        String   @id
  listingId String
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  Listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

model ModerationAction {
  id             String              @id
  caseId         String
  moderatorId    String
  action         ModeratorActionType
  reason         String?
  createdAt      DateTime            @default(now())
  ModerationCase ModerationCase      @relation(fields: [caseId], references: [id])
  User           User                @relation(fields: [moderatorId], references: [id])

  @@index([caseId])
  @@index([moderatorId])
}

model ModerationCase {
  id               String               @id
  reporterId       String
  targetType       ModerationTargetType
  targetId         String
  reason           ModerationReason
  description      String?
  status           ModerationStatus     @default(PENDING)
  userId           String?
  listingId        String?
  orderId          String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime
  resolvedAt       DateTime?
  ModerationAction ModerationAction[]
  Listing          Listing?             @relation(fields: [listingId], references: [id])
  Order            Order?               @relation(fields: [orderId], references: [id])
  User             User                 @relation(fields: [reporterId], references: [id])

  @@index([reporterId])
  @@index([status])
  @@index([targetType, targetId])
}

model NegotiationMessage {
  id                String            @id
  threadId          String
  content           String
  isAgent           Boolean           @default(false)
  createdAt         DateTime          @default(now())
  NegotiationThread NegotiationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
}

model NegotiationThread {
  id                                    String               @id
  listingId                             String
  buyerId                               String
  sellerId                              String
  status                                ThreadStatus         @default(ACTIVE)
  createdAt                             DateTime             @default(now())
  updatedAt                             DateTime
  closedAt                              DateTime?
  Bid                                   Bid[]
  NegotiationMessage                    NegotiationMessage[]
  User_NegotiationThread_buyerIdToUser  User                 @relation("NegotiationThread_buyerIdToUser", fields: [buyerId], references: [id])
  Listing                               Listing              @relation(fields: [listingId], references: [id], onDelete: Cascade)
  User_NegotiationThread_sellerIdToUser User                 @relation("NegotiationThread_sellerIdToUser", fields: [sellerId], references: [id])
  Order                                 Order?

  @@unique([listingId, buyerId])
  @@index([buyerId])
  @@index([listingId])
  @@index([sellerId])
  @@index([status])
}

model Notification {
  id        String           @id
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  User      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([read])
  @@index([userId])
}

model Order {
  id                String            @id
  threadId          String            @unique
  listingId         String            @unique
  buyerId           String
  sellerId          String
  amount            Int
  status            OrderStatus       @default(PENDING_PAYMENT)
  fulfillmentMethod FulfillmentMethod
  pickupLocation    String?
  deliveryAddress   String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime
  completedAt       DateTime?
  cancelledAt       DateTime?
  DeliveryRequest   DeliveryRequest?
  ModerationCase    ModerationCase[]
  User              User              @relation(fields: [buyerId], references: [id])
  Listing           Listing           @relation(fields: [listingId], references: [id])
  NegotiationThread NegotiationThread @relation(fields: [threadId], references: [id])
  Payment           Payment?

  @@index([buyerId])
  @@index([listingId])
  @@index([status])
  @@index([threadId])
}

model Payment {
  id              String        @id
  orderId         String        @unique
  stripePaymentId String?
  amount          Int
  status          PaymentStatus @default(PENDING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime
  paidAt          DateTime?
  refundedAt      DateTime?
  Order           Order         @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
}

model Profile {
  id          String   @id
  userId      String   @unique
  displayName String?
  bio         String?
  location    String?
  phone       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  User        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ReputationEvent {
  id        String              @id
  userId    String
  type      ReputationEventType
  points    Int
  reason    String
  createdAt DateTime            @default(now())
  User      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Session {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Skill {
  id               String           @id
  name             String           @unique
  displayName      String
  description      String
  category         SkillCategory
  isActive         Boolean          @default(true)
  config           Json?
  capabilities     Json
  costPerExecution Int?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime
  AgentSkill       AgentSkill[]
  SkillExecution   SkillExecution[]

  @@index([category])
  @@index([isActive])
}

model SkillExecution {
  id        String               @id
  agentId   String
  skillId   String
  input     Json
  output    Json?
  status    SkillExecutionStatus @default(PENDING)
  error     String?
  duration  Int?
  cost      Int?
  createdAt DateTime             @default(now())
  updatedAt DateTime
  Agent     Agent                @relation(fields: [agentId], references: [id], onDelete: Cascade)
  Skill     Skill                @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([createdAt])
  @@index([skillId])
  @@index([status])
}

model TrustSignal {
  id        String          @id
  userId    String
  type      TrustSignalType
  verified  Boolean         @default(false)
  createdAt DateTime        @default(now())
  expiresAt DateTime?
  User      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([type])
  @@index([userId])
}

model User {
  id                                                 String              @id
  email                                              String              @unique
  emailVerified                                      DateTime?
  name                                               String?
  image                                              String?
  password                                           String?
  createdAt                                          DateTime            @default(now())
  updatedAt                                          DateTime
  status                                             UserStatus          @default(ACTIVE)
  isBanned                                           Boolean             @default(false)
  bannedAt                                           DateTime?
  bannedReason                                       String?
  deletedAt                                          DateTime?
  Account                                            Account[]
  Agent                                              Agent[]
  AuditLog                                           AuditLog[]
  Listing                                            Listing[]
  ModerationAction                                   ModerationAction[]
  ModerationCase                                     ModerationCase[]
  NegotiationThread_NegotiationThread_buyerIdToUser  NegotiationThread[] @relation("NegotiationThread_buyerIdToUser")
  NegotiationThread_NegotiationThread_sellerIdToUser NegotiationThread[] @relation("NegotiationThread_sellerIdToUser")
  Notification                                       Notification[]
  Order                                              Order[]
  Profile                                            Profile?
  ReputationEvent                                    ReputationEvent[]
  Session                                            Session[]
  TrustSignal                                        TrustSignal[]
  WantedRequest                                      WantedRequest[]

  @@index([deletedAt])
  @@index([email])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model WantedRequest {
  id          String           @id
  userId      String
  agentId     String?
  title       String
  description String
  category    ListingCategory?
  maxPrice    Int?
  location    String?
  status      WantedStatus     @default(ACTIVE)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime
  fulfilledAt DateTime?
  Agent       Agent?           @relation(fields: [agentId], references: [id])
  User        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([status])
  @@index([userId])
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
  COUNTERED
  EXPIRED
}

enum DeliveryStatus {
  PENDING
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
}

enum FulfillmentMethod {
  PICKUP
  DELIVERY
}

enum ItemCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
  POOR
}

enum ListingCategory {
  FURNITURE
  ELECTRONICS
  CLOTHING
  BOOKS
  SPORTS
  TOYS
  TOOLS
  HOME_GARDEN
  VEHICLES
  OTHER
}

enum ListingStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  RESERVED
  SOLD
  REMOVED
  FLAGGED
  FOR_SALE
  TENTATIVE
}

enum ModerationReason {
  SPAM
  SCAM
  INAPPROPRIATE_CONTENT
  FAKE_LISTING
  HARASSMENT
  COUNTERFEIT
  PROHIBITED_ITEM
  PRICE_MANIPULATION
  OTHER
}

enum ModerationStatus {
  PENDING
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

enum ModerationTargetType {
  USER
  LISTING
  ORDER
  NEGOTIATION
}

enum ModeratorActionType {
  REMOVE_LISTING
  SUSPEND_USER
  BAN_USER
  WARN_USER
  REFUND_ORDER
  CANCEL_ORDER
  DISMISS
}

enum NotificationType {
  BID_RECEIVED
  BID_ACCEPTED
  BID_REJECTED
  BID_COUNTERED
  OFFER_EXPIRING
  PAYMENT_RECEIVED
  ORDER_SHIPPED
  ORDER_DELIVERED
  LISTING_FLAGGED
  AGENT_ACTION_REQUIRED
  DEAL_FOUND
  MODERATION_ACTION
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  IN_TRANSIT
  COMPLETED
  CANCELLED
  DISPUTED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum ReputationEventType {
  SUCCESSFUL_SALE
  SUCCESSFUL_PURCHASE
  POSITIVE_REVIEW
  NEGATIVE_REVIEW
  FLAGGED_LISTING
  SCAM_REPORT
  DISPUTE_RESOLVED
  DISPUTE_LOST
}

enum SkillCategory {
  ANALYSIS
  GENERATION
  AUTOMATION
  COMMUNICATION
  RESEARCH
  NEGOTIATION
}

enum SkillExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum ThreadStatus {
  ACTIVE
  ACCEPTED
  REJECTED
  EXPIRED
  CLOSED
}

enum TrustSignalType {
  EMAIL_VERIFIED
  PHONE_VERIFIED
  ID_VERIFIED
  ADDRESS_VERIFIED
  PAYMENT_METHOD_VERIFIED
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  DELETED
}

enum WantedStatus {
  ACTIVE
  FULFILLED
  CANCELLED
}
