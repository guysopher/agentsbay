// AgentBay - Prisma Schema
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["omitApi", "fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTH & USER MANAGEMENT
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique @omit(default: true)
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?   @omit(default: true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  profile       Profile?
  agents        Agent[]
  listings      Listing[]
  wantedRequests WantedRequest[]
  buyerThreads  NegotiationThread[] @relation("BuyerThreads")
  sellerThreads NegotiationThread[] @relation("SellerThreads")
  orders        Order[]
  moderationCases ModerationCase[]
  moderationActions ModerationAction[]
  auditLogs     AuditLog[]
  notifications Notification[]
  reputationEvents ReputationEvent[]
  trustSignals  TrustSignal[]

  // Status
  status        UserStatus @default(ACTIVE)
  isBanned      Boolean    @default(false)
  bannedAt      DateTime?
  bannedReason  String?

  // Soft delete
  deletedAt     DateTime?

  @@index([email])
  @@index([deletedAt])
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  DELETED
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String?
  bio         String?
  location    String?
  phone       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================
// AGENTS
// ============================================

model Agent {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // Agent settings
  autoNegotiate    Boolean @default(false)
  maxBidAmount     Int?    // Max amount agent can bid (cents)
  minAcceptAmount  Int?    // Min amount agent will auto-accept (cents)
  maxAcceptAmount  Int?    // Max amount agent will auto-accept (cents)
  autoRejectBelow  Int?    // Auto-reject offers below this (cents)
  autoCounterEnabled Boolean @default(false)
  requireApproval  Boolean @default(true)

  // Location preferences
  preferredLocation String?
  maxDistance       Int?    // Max distance in km

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentials AgentCredential[]
  listings    Listing[]
  wantedRequests WantedRequest[]
  bids        Bid[]
  auditLogs   AuditLog[]
  agentSkills AgentSkill[]
  skillExecutions SkillExecution[]

  @@index([userId])
  @@index([isActive])
  @@index([deletedAt])
}

model AgentCredential {
  id        String   @id @default(cuid())
  agentId   String
  provider  String   // e.g., "openai", "anthropic"
  apiKey    String   // Encrypted
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
}

// ============================================
// SKILLS
// ============================================

model Skill {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String
  description String
  category    SkillCategory
  isActive    Boolean  @default(true)

  // Skill configuration
  config      Json?    // Skill-specific configuration

  // Capabilities
  capabilities Json    // List of what the skill can do

  // Pricing
  costPerExecution Int? // Cost in credits (nullable for free skills)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  agentSkills AgentSkill[]
  executions  SkillExecution[]

  @@index([category])
  @@index([isActive])
}

enum SkillCategory {
  ANALYSIS      // Code analysis, item analysis
  GENERATION    // Content generation, descriptions
  AUTOMATION    // Automated actions
  COMMUNICATION // Messaging, emails
  RESEARCH      // Market research, price analysis
  NEGOTIATION   // Negotiation strategies
}

model AgentSkill {
  id        String   @id @default(cuid())
  agentId   String
  skillId   String

  isEnabled Boolean  @default(true)

  // Skill-specific settings for this agent
  settings  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([agentId, skillId])
  @@index([agentId])
  @@index([skillId])
}

model SkillExecution {
  id        String   @id @default(cuid())
  agentId   String
  skillId   String

  // Execution context
  input     Json     // Input parameters
  output    Json?    // Execution result

  // Status
  status    SkillExecutionStatus @default(PENDING)
  error     String?  // Error message if failed

  // Metadata
  duration  Int?     // Execution time in ms
  cost      Int?     // Cost in credits

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([skillId])
  @@index([status])
  @@index([createdAt])
}

enum SkillExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

// ============================================
// LISTINGS
// ============================================

model Listing {
  id          String   @id @default(cuid())
  userId      String
  agentId     String?  // Optional: created by agent

  // Content
  title       String
  description String
  category    ListingCategory
  condition   ItemCondition
  price       Int      // in cents
  location    String

  // Metadata
  status      ListingStatus @default(DRAFT)
  confidence  Float?   // AI confidence score for enriched listings

  // Fulfillment
  pickupAvailable    Boolean @default(true)
  deliveryAvailable  Boolean @default(false)

  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  publishedAt DateTime?
  soldAt      DateTime?
  deletedAt   DateTime?

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent       Agent?   @relation(fields: [agentId], references: [id])
  images      ListingImage[]
  threads     NegotiationThread[]
  order       Order?
  moderationCases ModerationCase[]
  auditLogs   AuditLog[]

  @@index([userId])
  @@index([agentId])
  @@index([status])
  @@index([category])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([price])
  @@fulltext([title, description])
}

enum ListingCategory {
  FURNITURE
  ELECTRONICS
  CLOTHING
  BOOKS
  SPORTS
  TOYS
  TOOLS
  HOME_GARDEN
  VEHICLES
  OTHER
}

enum ItemCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
  POOR
}

enum ListingStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  RESERVED
  SOLD
  REMOVED
  FLAGGED
}

model ListingImage {
  id        String   @id @default(cuid())
  listingId String
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

// ============================================
// WANTED REQUESTS
// ============================================

model WantedRequest {
  id          String   @id @default(cuid())
  userId      String
  agentId     String?

  title       String
  description String
  category    ListingCategory?
  maxPrice    Int?     // in cents
  location    String?

  status      WantedStatus @default(ACTIVE)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  fulfilledAt DateTime?

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent Agent? @relation(fields: [agentId], references: [id])

  @@index([userId])
  @@index([agentId])
  @@index([status])
}

enum WantedStatus {
  ACTIVE
  FULFILLED
  CANCELLED
}

// ============================================
// NEGOTIATIONS
// ============================================

model NegotiationThread {
  id         String   @id @default(cuid())
  listingId  String
  buyerId    String
  sellerId   String

  status     ThreadStatus @default(ACTIVE)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  closedAt   DateTime?

  // Relations
  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer      User     @relation("BuyerThreads", fields: [buyerId], references: [id])
  seller     User     @relation("SellerThreads", fields: [sellerId], references: [id])
  bids       Bid[]
  messages   NegotiationMessage[]
  order      Order?

  @@unique([listingId, buyerId])
  @@index([listingId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
}

enum ThreadStatus {
  ACTIVE
  ACCEPTED
  REJECTED
  EXPIRED
  CLOSED
}

model Bid {
  id        String   @id @default(cuid())
  threadId  String
  agentId   String?  // If made by agent

  amount    Int      // in cents
  message   String?

  status    BidStatus @default(PENDING)
  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  thread    NegotiationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  agent     Agent?   @relation(fields: [agentId], references: [id])

  @@index([threadId])
  @@index([agentId])
  @@index([status])
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
  COUNTERED
  EXPIRED
}

model NegotiationMessage {
  id        String   @id @default(cuid())
  threadId  String

  content   String
  isAgent   Boolean  @default(false)

  createdAt DateTime @default(now())

  thread    NegotiationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
}

// ============================================
// ORDERS & PAYMENTS
// ============================================

model Order {
  id        String   @id @default(cuid())
  threadId  String   @unique
  listingId String   @unique
  buyerId   String
  sellerId  String

  amount    Int      // Final agreed price in cents
  status    OrderStatus @default(PENDING_PAYMENT)

  // Fulfillment
  fulfillmentMethod FulfillmentMethod
  pickupLocation    String?
  deliveryAddress   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  completedAt DateTime?
  cancelledAt DateTime?

  // Relations
  thread    NegotiationThread @relation(fields: [threadId], references: [id])
  listing   Listing  @relation(fields: [listingId], references: [id])
  buyer     User     @relation(fields: [buyerId], references: [id])
  payment   Payment?
  deliveryRequest DeliveryRequest?
  moderationCases ModerationCase[]

  @@index([threadId])
  @@index([listingId])
  @@index([buyerId])
  @@index([status])
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  IN_TRANSIT
  COMPLETED
  CANCELLED
  DISPUTED
  REFUNDED
}

enum FulfillmentMethod {
  PICKUP
  DELIVERY
}

model Payment {
  id              String   @id @default(cuid())
  orderId         String   @unique

  stripePaymentId String?  // Stripe payment intent ID
  amount          Int      // in cents
  status          PaymentStatus @default(PENDING)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  paidAt          DateTime?
  refundedAt      DateTime?

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

model DeliveryRequest {
  id        String   @id @default(cuid())
  orderId   String   @unique

  provider  String?  // e.g., "ups", "fedex"
  trackingNumber String?

  status    DeliveryStatus @default(PENDING)

  fromAddress String
  toAddress   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  pickedUpAt DateTime?
  deliveredAt DateTime?

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
}

enum DeliveryStatus {
  PENDING
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
}

// ============================================
// TRUST & SAFETY
// ============================================

model ReputationEvent {
  id        String   @id @default(cuid())
  userId    String

  type      ReputationEventType
  points    Int      // Can be positive or negative
  reason    String

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum ReputationEventType {
  SUCCESSFUL_SALE
  SUCCESSFUL_PURCHASE
  POSITIVE_REVIEW
  NEGATIVE_REVIEW
  FLAGGED_LISTING
  SCAM_REPORT
  DISPUTE_RESOLVED
  DISPUTE_LOST
}

model TrustSignal {
  id        String   @id @default(cuid())
  userId    String

  type      TrustSignalType
  verified  Boolean  @default(false)

  createdAt DateTime @default(now())
  expiresAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
}

enum TrustSignalType {
  EMAIL_VERIFIED
  PHONE_VERIFIED
  ID_VERIFIED
  ADDRESS_VERIFIED
  PAYMENT_METHOD_VERIFIED
}

model ModerationCase {
  id          String   @id @default(cuid())
  reporterId  String

  targetType  ModerationTargetType
  targetId    String   // ID of listing, user, order, etc.

  reason      ModerationReason
  description String?
  status      ModerationStatus @default(PENDING)

  // Relations (nullable because target can be different types)
  userId      String?
  listingId   String?
  orderId     String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  resolvedAt  DateTime?

  reporter User     @relation(fields: [reporterId], references: [id])
  listing  Listing? @relation(fields: [listingId], references: [id])
  order    Order?   @relation(fields: [orderId], references: [id])
  actions  ModerationAction[]

  @@index([reporterId])
  @@index([targetType, targetId])
  @@index([status])
}

enum ModerationTargetType {
  USER
  LISTING
  ORDER
  NEGOTIATION
}

enum ModerationReason {
  SPAM
  SCAM
  INAPPROPRIATE_CONTENT
  FAKE_LISTING
  HARASSMENT
  COUNTERFEIT
  PROHIBITED_ITEM
  PRICE_MANIPULATION
  OTHER
}

enum ModerationStatus {
  PENDING
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

model ModerationAction {
  id        String   @id @default(cuid())
  caseId    String
  moderatorId String

  action    ModeratorActionType
  reason    String?

  createdAt DateTime @default(now())

  case      ModerationCase @relation(fields: [caseId], references: [id])
  moderator User @relation(fields: [moderatorId], references: [id])

  @@index([caseId])
  @@index([moderatorId])
}

enum ModeratorActionType {
  REMOVE_LISTING
  SUSPEND_USER
  BAN_USER
  WARN_USER
  REFUND_ORDER
  CANCEL_ORDER
  DISMISS
}

// ============================================
// AUDIT & NOTIFICATIONS
// ============================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  agentId   String?

  action    String   // e.g., "listing.created", "bid.accepted"
  entityType String  // e.g., "listing", "order"
  entityId  String

  metadata  Json?    // Additional context

  createdAt DateTime @default(now())

  user    User?    @relation(fields: [userId], references: [id])
  agent   Agent?   @relation(fields: [agentId], references: [id])
  listing Listing? @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([agentId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String

  type      NotificationType
  title     String
  message   String
  link      String?

  read      Boolean  @default(false)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
}

enum NotificationType {
  BID_RECEIVED
  BID_ACCEPTED
  BID_REJECTED
  BID_COUNTERED
  OFFER_EXPIRING
  PAYMENT_RECEIVED
  ORDER_SHIPPED
  ORDER_DELIVERED
  LISTING_FLAGGED
  AGENT_ACTION_REQUIRED
  DEAL_FOUND
  MODERATION_ACTION
}
