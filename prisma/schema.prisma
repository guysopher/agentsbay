// AgentBay Prisma Schema
// Database schema for the AI agent-powered secondhand marketplace
// Last updated: 2026-03-25

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// AUTHENTICATION MODELS (NextAuth.js)
// ============================================================================

/// OAuth account connections (Google, GitHub, etc.)
/// Used by NextAuth for third-party authentication
model Account {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// ============================================================================
// AGENT MODELS
// ============================================================================

/// AI Agent that can buy/sell on behalf of a user
/// Supports autonomous negotiation with configurable limits
/// Max 5 agents per user
model Agent {
  id                 String            @id
  userId             String            // Owner of the agent
  name               String            @default("Agent")
  description        String?           // Agent's purpose/description

  // Lifecycle
  isActive           Boolean           @default(true)  // Agent can be temporarily disabled
  createdAt          DateTime          @default(now())
  updatedAt          DateTime
  deletedAt          DateTime?         // Soft delete timestamp

  // Negotiation Settings
  autoNegotiate      Boolean           @default(false)         // Enable autonomous negotiation
  maxBidAmount       Int?                                      // Max amount agent can bid (cents)
  minAcceptAmount    Int?                                      // Auto-accept bids above this (cents)
  maxAcceptAmount    Int?                                      // Auto-accept bids below this (cents)
  autoRejectBelow    Int?                                      // Auto-reject bids below this (cents)
  autoCounterEnabled Boolean           @default(false)         // Enable auto-counter offers
  requireApproval    Boolean           @default(true)          // Require human approval for actions

  // Location Preferences
  preferredLocation  String?           // Preferred search location
  maxDistance        Int?              // Max distance for searches (km)
  currency           String?           // Preferred currency
  latitude           Float?            // Location coordinates
  longitude          Float?
  locale             String?           // Locale for formatting
  User               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  AgentCredential    AgentCredential[]
  AgentSkill         AgentSkill[]
  AuditLog           AuditLog[]
  Bid                Bid[]
  Listing            Listing[]
  SkillExecution     SkillExecution[]
  WantedRequest      WantedRequest[]
  Webhook            Webhook[]

  @@index([deletedAt])
  @@index([isActive])
  @@index([userId])
}

model AgentCredential {
  id        String   @id
  agentId   String
  provider  String
  apiKey    String
  createdAt DateTime @default(now())
  updatedAt DateTime
  Agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
}

/// Junction table linking agents to skills
/// Allows enabling/disabling skills per agent with custom settings
model AgentSkill {
  id        String   @id
  agentId   String
  skillId   String
  isEnabled Boolean  @default(true)
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime
  Agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  Skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([agentId, skillId])
  @@index([agentId])
  @@index([skillId])
}

// ============================================================================
// AUDIT & LOGGING
// ============================================================================

/// Audit log for tracking all user and agent actions
/// Immutable record of who did what and when
model AuditLog {
  id         String   @id
  userId     String?           // User who performed action (if user)
  agentId    String?           // Agent who performed action (if agent)
  action     String            // Action performed (e.g., "listing.created")
  entityType String            // Type of entity (e.g., "listing", "bid")
  entityId   String            // ID of the affected entity
  metadata   Json?             // Additional context (JSON)
  createdAt  DateTime @default(now())
  Agent      Agent?   @relation(fields: [agentId], references: [id])
  User       User?    @relation(fields: [userId], references: [id])

  @@index([agentId])
  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([userId])
}

// ============================================================================
// MARKETPLACE MODELS
// ============================================================================

/// Individual bid/offer in a negotiation
/// Part of a NegotiationThread between buyer and seller
/// Status transitions: PENDING → ACCEPTED/REJECTED/COUNTERED/EXPIRED
model Bid {
  id                String            @id
  threadId          String            // Negotiation thread this bid belongs to
  agentId           String?           // Agent that placed bid (if agent-initiated)
  placedByUserId    String?           // User who placed this bid (for turn enforcement)
  amount            Int               // Bid amount in minor currency units (cents)
  message           String?           // Optional message with bid
  status            BidStatus         @default(PENDING)
  expiresAt         DateTime?         // When bid expires (optional)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime
  Agent             Agent?            @relation(fields: [agentId], references: [id])
  NegotiationThread NegotiationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([status])
  @@index([threadId])
}

model DeliveryRequest {
  id             String         @id
  orderId        String         @unique
  provider       String?
  trackingNumber String?
  status         DeliveryStatus @default(PENDING)
  fromAddress    String
  toAddress      String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime
  pickedUpAt     DateTime?
  deliveredAt    DateTime?
  Order          Order          @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
}

/// Marketplace listing for a used item
/// Status flow: DRAFT → PUBLISHED → SOLD/REMOVED
/// Can be created by users or agents
model Listing {
  id                String              @id
  userId            String              // Owner of the listing
  agentId           String?             // Agent that created listing (if agent-created)

  // Item Details
  title             String              // Item title (3-200 chars)
  description       String              // Item description (10-5000 chars)
  category          ListingCategory     // Item category
  condition         ItemCondition       // Item condition
  price             Int                 // Price in minor currency units (cents)
  currency          String              @default("USD")
  labels            String[]            @default([])  // Tags/keywords

  // Location (NO apartment/unit numbers for privacy)
  address           String              // Street address or city only
  latitude          Float?              // Geocoded coordinates
  longitude         Float?

  // Status & Lifecycle
  status            ListingStatus       @default(DRAFT)
  confidence        Float?              // AI confidence score (if AI-generated)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  publishedAt       DateTime?           // When published to marketplace
  soldAt            DateTime?           // When marked as sold
  deletedAt         DateTime?           // Soft delete timestamp

  // Delivery Options
  pickupAvailable   Boolean             @default(true)
  deliveryAvailable Boolean             @default(false)
  priceMax          Int?
  contactDiscord    String?
  contactTelegram   String?
  contactWhatsApp   String?

  // Duplicate detection
  duplicateOfId     String?             // ID of original listing this duplicates (for moderation)
  DuplicateOf       Listing?            @relation("DuplicateListings", fields: [duplicateOfId], references: [id])
  Duplicates        Listing[]           @relation("DuplicateListings")

  Agent             Agent?              @relation(fields: [agentId], references: [id])
  User              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  ListingImage      ListingImage[]
  ModerationCase    ModerationCase[]
  NegotiationThread NegotiationThread[]
  Order             Order?

  @@index([agentId])
  @@index([category])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([duplicateOfId])
  @@index([price])
  @@index([status])
  @@index([userId])
}

model ListingImage {
  id        String   @id
  listingId String
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  Listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

model ModerationAction {
  id             String              @id
  caseId         String
  moderatorId    String
  action         ModeratorActionType
  reason         String?
  createdAt      DateTime            @default(now())
  ModerationCase ModerationCase      @relation(fields: [caseId], references: [id])
  User           User                @relation(fields: [moderatorId], references: [id])

  @@index([caseId])
  @@index([moderatorId])
}

model ModerationCase {
  id               String               @id
  reporterId       String
  targetType       ModerationTargetType
  targetId         String
  reason           ModerationReason
  description      String?
  status           ModerationStatus     @default(PENDING)
  userId           String?
  listingId        String?
  orderId          String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime
  resolvedAt       DateTime?
  ModerationAction ModerationAction[]
  Listing          Listing?             @relation(fields: [listingId], references: [id])
  Order            Order?               @relation(fields: [orderId], references: [id])
  User             User                 @relation(fields: [reporterId], references: [id])

  @@index([reporterId])
  @@index([status])
  @@index([targetType, targetId])
}

model NegotiationMessage {
  id                String            @id
  threadId          String
  content           String
  isAgent           Boolean           @default(false)
  createdAt         DateTime          @default(now())
  NegotiationThread NegotiationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
}

model NegotiationThread {
  id                                    String               @id
  listingId                             String
  buyerId                               String
  sellerId                              String
  status                                ThreadStatus         @default(ACTIVE)
  createdAt                             DateTime             @default(now())
  updatedAt                             DateTime
  closedAt                              DateTime?
  Bid                                   Bid[]
  NegotiationMessage                    NegotiationMessage[]
  User_NegotiationThread_buyerIdToUser  User                 @relation("NegotiationThread_buyerIdToUser", fields: [buyerId], references: [id])
  Listing                               Listing              @relation(fields: [listingId], references: [id], onDelete: Cascade)
  User_NegotiationThread_sellerIdToUser User                 @relation("NegotiationThread_sellerIdToUser", fields: [sellerId], references: [id])
  Order                                 Order?

  @@unique([listingId, buyerId])
  @@index([buyerId])
  @@index([listingId])
  @@index([sellerId])
  @@index([status])
}

model Notification {
  id        String           @id
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  User      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([read])
  @@index([userId])
}

model Order {
  id                String            @id
  threadId          String            @unique
  listingId         String            @unique
  buyerId           String
  sellerId          String
  amount            Int
  status            OrderStatus       @default(PENDING_PAYMENT)
  fulfillmentMethod FulfillmentMethod
  pickupLocation    String?
  deliveryAddress   String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime
  completedAt       DateTime?
  cancelledAt       DateTime?
  DeliveryRequest   DeliveryRequest?
  ModerationCase    ModerationCase[]
  Review            Review[]
  User              User              @relation(fields: [buyerId], references: [id])
  Listing           Listing           @relation(fields: [listingId], references: [id])
  NegotiationThread NegotiationThread @relation(fields: [threadId], references: [id])
  Payment           Payment?

  @@index([buyerId])
  @@index([listingId])
  @@index([status])
  @@index([threadId])
}

model Payment {
  id              String        @id
  orderId         String        @unique
  stripePaymentId String?
  amount          Int
  status          PaymentStatus @default(PENDING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime
  paidAt          DateTime?
  refundedAt      DateTime?
  Order           Order         @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
}

model Profile {
  id          String   @id
  userId      String   @unique
  displayName String?
  bio         String?
  location    String?
  phone       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  User        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ReputationEvent {
  id        String              @id
  userId    String
  type      ReputationEventType
  points    Int
  reason    String
  createdAt DateTime            @default(now())
  User      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Session {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Skill {
  id               String           @id
  name             String           @unique
  displayName      String
  description      String
  category         SkillCategory
  isActive         Boolean          @default(true)
  config           Json?
  capabilities     Json
  costPerExecution Int?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime
  AgentSkill       AgentSkill[]
  SkillExecution   SkillExecution[]

  @@index([category])
  @@index([isActive])
}

model SkillExecution {
  id        String               @id
  agentId   String
  skillId   String
  input     Json
  output    Json?
  status    SkillExecutionStatus @default(PENDING)
  error     String?
  duration  Int?
  cost      Int?
  createdAt DateTime             @default(now())
  updatedAt DateTime
  Agent     Agent                @relation(fields: [agentId], references: [id], onDelete: Cascade)
  Skill     Skill                @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([createdAt])
  @@index([skillId])
  @@index([status])
}

model TrustSignal {
  id        String          @id
  userId    String
  type      TrustSignalType
  verified  Boolean         @default(false)
  createdAt DateTime        @default(now())
  expiresAt DateTime?
  User      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([type])
  @@index([userId])
}

model Review {
  id         String   @id
  orderId    String
  reviewerId String
  revieweeId String
  rating     Int      // 1–5
  comment    String?  // max 1000 chars
  createdAt  DateTime @default(now())

  Order    Order @relation(fields: [orderId], references: [id])
  Reviewer User  @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  Reviewee User  @relation("ReviewsReceived", fields: [revieweeId], references: [id])

  @@unique([orderId, reviewerId])
  @@index([revieweeId])
  @@index([orderId])
}

model User {
  id                                                 String              @id
  email                                              String              @unique
  emailVerified                                      DateTime?
  name                                               String?
  image                                              String?
  password                                           String?
  createdAt                                          DateTime            @default(now())
  updatedAt                                          DateTime
  status                                             UserStatus          @default(ACTIVE)
  isBanned                                           Boolean             @default(false)
  bannedAt                                           DateTime?
  bannedReason                                       String?
  deletedAt                                          DateTime?
  stripeAccountId                                    String?             // Stripe Connect account ID for sellers
  Account                                            Account[]
  Agent                                              Agent[]
  AuditLog                                           AuditLog[]
  Listing                                            Listing[]
  ModerationAction                                   ModerationAction[]
  ModerationCase                                     ModerationCase[]
  NegotiationThread_NegotiationThread_buyerIdToUser  NegotiationThread[] @relation("NegotiationThread_buyerIdToUser")
  NegotiationThread_NegotiationThread_sellerIdToUser NegotiationThread[] @relation("NegotiationThread_sellerIdToUser")
  Notification                                       Notification[]
  Order                                              Order[]
  Profile                                            Profile?
  ReputationEvent                                    ReputationEvent[]
  ReviewsGiven                                       Review[]            @relation("ReviewsGiven")
  ReviewsReceived                                    Review[]            @relation("ReviewsReceived")
  Session                                            Session[]
  TrustSignal                                        TrustSignal[]
  WantedRequest                                      WantedRequest[]

  @@index([deletedAt])
  @@index([email])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Webhook {
  id              String            @id
  agentId         String
  url             String
  events          String[]          // e.g. ["bid.received", "order.status_changed"]
  secret          String            // HMAC signing secret
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  Agent           Agent             @relation(fields: [agentId], references: [id], onDelete: Cascade)
  WebhookDelivery WebhookDelivery[]

  @@index([agentId])
  @@index([agentId, isActive])
}

model WebhookDelivery {
  id          String    @id
  webhookId   String
  event       String
  payload     Json
  statusCode  Int?
  error       String?
  deliveredAt DateTime?
  createdAt   DateTime  @default(now())
  Webhook     Webhook   @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([createdAt])
}

model WantedRequest {
  id          String           @id
  userId      String
  agentId     String?
  title       String
  description String
  category    ListingCategory?
  maxPrice    Int?
  location    String?
  status      WantedStatus     @default(ACTIVE)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime
  fulfilledAt DateTime?
  Agent       Agent?           @relation(fields: [agentId], references: [id])
  User        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([status])
  @@index([userId])
}

// ============================================================================
// ENUMS
// ============================================================================

/// Bid lifecycle states
/// Flow: PENDING → ACCEPTED/REJECTED/COUNTERED/EXPIRED
enum BidStatus {
  PENDING    // Awaiting seller response
  ACCEPTED   // Seller accepted bid (listing sold)
  REJECTED   // Seller rejected bid
  COUNTERED  // Seller made counter-offer (new bid created)
  EXPIRED    // Bid expired before response
}

/// Delivery tracking states (Phase 4)
enum DeliveryStatus {
  PENDING
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
}

enum FulfillmentMethod {
  PICKUP
  DELIVERY
}

/// Item condition ratings
/// Used for setting buyer expectations
enum ItemCondition {
  NEW       // Brand new, never used
  LIKE_NEW  // Barely used, excellent condition
  GOOD      // Used but well-maintained
  FAIR      // Shows wear, fully functional
  POOR      // Heavy wear, may have issues
}

/// Product categories for listings
/// Used for search filtering and organization
enum ListingCategory {
  FURNITURE     // Chairs, tables, sofas, etc.
  ELECTRONICS   // Laptops, phones, cameras, etc.
  CLOTHING      // Apparel and accessories
  BOOKS         // Books and magazines
  SPORTS        // Sports equipment
  TOYS          // Toys and games
  TOOLS         // Hand tools, power tools
  HOME_GARDEN   // Home decor, garden items
  VEHICLES      // Cars, bikes, scooters
  OTHER         // Uncategorized items
}

/// Listing lifecycle states
/// Flow: DRAFT → [PENDING_REVIEW] → PUBLISHED ⇄ PAUSED → SOLD/REMOVED
enum ListingStatus {
  DRAFT           // Not yet published
  PENDING_REVIEW  // Awaiting moderation (Phase 5)
  PUBLISHED       // Live in marketplace
  PAUSED          // Seller temporarily paused listing
  RESERVED        // Item reserved pending pickup
  SOLD            // Transaction completed
  REMOVED         // Listing removed (soft delete)
  FLAGGED         // Flagged for review (Phase 5)
  FOR_SALE        // Legacy status
  TENTATIVE       // Legacy status
}

enum ModerationReason {
  SPAM
  SCAM
  INAPPROPRIATE_CONTENT
  FAKE_LISTING
  HARASSMENT
  COUNTERFEIT
  PROHIBITED_ITEM
  PRICE_MANIPULATION
  OTHER
}

enum ModerationStatus {
  PENDING
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

enum ModerationTargetType {
  USER
  LISTING
  ORDER
  NEGOTIATION
}

enum ModeratorActionType {
  REMOVE_LISTING
  SUSPEND_USER
  BAN_USER
  WARN_USER
  REFUND_ORDER
  CANCEL_ORDER
  DISMISS
}

enum NotificationType {
  BID_RECEIVED
  BID_ACCEPTED
  BID_REJECTED
  BID_COUNTERED
  OFFER_EXPIRING
  PAYMENT_RECEIVED
  ORDER_SHIPPED
  ORDER_DELIVERED
  LISTING_FLAGGED
  AGENT_ACTION_REQUIRED
  DEAL_FOUND
  MODERATION_ACTION
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  IN_TRANSIT
  COMPLETED
  CANCELLED
  DISPUTED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum ReputationEventType {
  SUCCESSFUL_SALE
  SUCCESSFUL_PURCHASE
  POSITIVE_REVIEW
  NEGATIVE_REVIEW
  FLAGGED_LISTING
  SCAM_REPORT
  DISPUTE_RESOLVED
  DISPUTE_LOST
}

enum SkillCategory {
  ANALYSIS
  GENERATION
  AUTOMATION
  COMMUNICATION
  RESEARCH
  NEGOTIATION
}

enum SkillExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

/// Negotiation thread lifecycle states
/// Flow: ACTIVE → ACCEPTED/REJECTED/EXPIRED
enum ThreadStatus {
  ACTIVE    // Negotiation in progress
  ACCEPTED  // Bid accepted, deal made
  REJECTED  // All bids rejected
  EXPIRED   // Thread expired without resolution
  CLOSED
}

enum TrustSignalType {
  EMAIL_VERIFIED
  PHONE_VERIFIED
  ID_VERIFIED
  ADDRESS_VERIFIED
  PAYMENT_METHOD_VERIFIED
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  DELETED
}

enum WantedStatus {
  ACTIVE
  FULFILLED
  CANCELLED
}
