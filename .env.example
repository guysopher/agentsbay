# Database (required)
DATABASE_URL="postgresql://user:password@localhost:5432/agentbay"

# Auth (required)
NEXTAUTH_URL="http://localhost:3000"
# Generate a secure secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-change-in-production-min-32-chars"

# Public site URL for metadata, sitemap, robots.txt, and growth links
# Set this to your production host at launch, e.g. https://agentsbay.org
AGENTSBAY_BASE_URL="http://localhost:3000"

# Public app URL used by the site-config module (falls back to NEXTAUTH_URL)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Node Environment
NODE_ENV="development"

# Admin user IDs (optional — comma-separated NextAuth user IDs with admin access)
ADMIN_USER_IDS=""

# Email domain used when creating synthetic user accounts for agent registrations (optional)
AGENT_EMAIL_DOMAIN="agent.agentbay.com"

# OpenAI (optional - for Phase 2+ agent features)
OPENAI_API_KEY=""

# Stripe (optional - for Phase 4+ payments)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Cron (optional - authenticate /api/cron/* endpoints; generate with: openssl rand -hex 32)
CRON_SECRET=""

# Redis (optional - for Phase 6+ caching)
REDIS_URL=""

# Plausible Analytics (optional - privacy-friendly, cookieless analytics)
# Set to your domain registered in Plausible (e.g. agentsbay.org)
# Leave empty in development to avoid polluting analytics data
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""

# Sentry (optional - for monitoring and error tracking)
# Get your DSN from https://sentry.io → Project Settings → Client Keys
SENTRY_DSN=""
# Also expose DSN to the client bundle (same value as SENTRY_DSN)
NEXT_PUBLIC_SENTRY_DSN=""
# For source map uploads during CI builds (optional)
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
TELEGRAM_BOARD_CHAT_ID=""

# Waitlist form (optional - Tally.so free tier form ID for email capture)
# Create a form at https://tally.so with fields: email + "What do you want to use AgentsBay for?"
# Then set this to your form ID (e.g. from https://tally.so/r/FORM_ID → set to just "FORM_ID")
NEXT_PUBLIC_TALLY_FORM_ID=""
