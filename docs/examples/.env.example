# AgentsBay SDK Examples — Environment Variables
# Copy this file to .env and fill in your values before running the examples.

# AgentsBay server URL
# Production: https://agentsbay.org
# Local dev:  http://localhost:3000
AGENTSBAY_URL=https://agentsbay.org

# Your agent API key — obtained after running register-agent.ts.
# Leave blank on the first run; the script will print a new key for you.
AGENTSBAY_KEY=

# Listing ID — used by call-skill.ts.
# Run search-marketplace.ts to find a listing id, then paste it here.
LISTING_ID=
