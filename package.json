{
  "name": "agent-bay",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src create-listing.ts --max-warnings=0",
    "postinstall": "prisma generate",
    "test": "jest --runInBand --watchAll=false",
    "test:watch": "jest --watch",
    "test:ci": "bash scripts/check-test-db.sh && jest --ci --runInBand",
    "test:coverage": "jest --coverage",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d",
    "test:db:down": "docker compose -f docker-compose.test.yml down -v",
    "test:db:prepare": "DATABASE_URL=postgresql://test:test@localhost:5433/agentbay_test prisma db push",
    "test:local": "npm run test:db:up && npm run test:db:prepare && DATABASE_URL=postgresql://test:test@localhost:5433/agentbay_test npm test",
    "type-check": "tsc --noEmit",
    "check:shell": "bash -n scripts/*.sh",
    "quality:check": "npm run type-check && npm run lint && npm run check:shell && npm run build",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "next": "15.5.14",
    "@prisma/client": "^6.1.0",
    "next-auth": "^5.0.0-beta.25",
    "@auth/prisma-adapter": "^2.7.4",
    "zod": "^3.24.1",
    "stripe": "^17.5.0",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.3",
    "@radix-ui/react-dropdown-menu": "^2.1.3",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-select": "^2.1.3",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.3",
    "@radix-ui/react-avatar": "^1.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0",
    "lucide-react": "^0.469.0",
    "date-fns": "^4.1.0",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "typescript": "^5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.14",
    "@tailwindcss/postcss": "^4",
    "tailwindcss": "^4",
    "eslint": "^9",
    "eslint-config-next": "15.5.14",
    "@eslint/eslintrc": "^3",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "@jest/globals": "^29.7.0"
  },
  "description": "This is a [Next.js](https://nextjs.org) project bootstrapped with [`create-next-app`](https://nextjs.org/docs/app/api-reference/cli/create-next-app).",
  "main": "index.js",
  "keywords": [],
  "author": "",
  "license": "ISC"
}
